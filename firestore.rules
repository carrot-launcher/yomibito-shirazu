rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // ===== ヘルパー関数 =====
    function isAuth() {
      return request.auth != null;
    }
    function isGroupMember(groupId) {
      return isAuth() &&
        exists(/databases/$(db)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }
    function isGroupOwner(groupId) {
      return isAuth() &&
        get(/databases/$(db)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'owner';
    }
    function isBanned(groupId) {
      let groupData = get(/databases/$(db)/documents/groups/$(groupId)).data;
      return 'bannedUsers' in groupData && request.auth.uid in groupData.bannedUsers;
    }
    // 過去にその歌会のメンバーだった（退会者）。追放者は bannedUsers に入るだけで
    // ここには載せない設計（leaveGroup のみが pastMembers を追加する）。
    function wasGroupMember(groupId) {
      let groupData = get(/databases/$(db)/documents/groups/$(groupId)).data;
      return 'pastMembers' in groupData && request.auth.uid in groupData.pastMembers;
    }
    function isGroupPublic(groupId) {
      let groupData = get(/databases/$(db)/documents/groups/$(groupId)).data;
      return groupData.get('isPublic', false) == true;
    }
    // 自分の歌か（myPosts の doc ID は postId と一致している前提）。
    // 退会・追放後でも自分の歌を読み取り／削除ルートに乗せるための判定。
    function isOwnPost(postId) {
      return exists(/databases/$(db)/documents/users/$(request.auth.uid)/myPosts/$(postId));
    }
    // 歌会が解散済み＝groupドキュメント不在。
    function isGroupDissolved(groupId) {
      return !exists(/databases/$(db)/documents/groups/$(groupId));
    }
    // post の作者を自分がブロック中、または作者が自分をブロック中か判定
    // （双方向のブロック関係で reactions 等の干渉を遮断するため）。
    // どこか 1 ステップでも想定外だったらブロック関係なし扱いにして、ルール評価エラーで
    // リアクション全体が落ちないようにする。
    function hasBlockRelation(postId) {
      let postData = get(/databases/$(db)/documents/posts/$(postId)).data;
      let myDoc = get(/databases/$(db)/documents/users/$(request.auth.uid)).data;
      let handle = postData.authorHandle;
      let blocked = 'blockedHandles' in myDoc ? myDoc.blockedHandles : {};
      let blockedBy = 'blockedByHandles' in myDoc ? myDoc.blockedByHandles : {};
      return handle is string
             && blocked is map
             && blockedBy is map
             && (handle in blocked || handle in blockedBy);
    }

    // ===== レートリミットカウンタ（サーバー専用） =====
    match /rateLimits/{document=**} {
      allow read, write: if false;
    }

    // ===== 設定（管理者のみ Firebase Console から編集） =====
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ===== users =====
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if request.auth.uid == userId;

      // 歌集（自分の投稿一覧）
      match /myPosts/{myPostId} {
        allow read: if request.auth.uid == userId;
        allow write: if request.auth.uid == userId;
      }

      // 栞（ブックマーク）
      match /bookmarks/{postId} {
        allow read, write: if request.auth.uid == userId;
      }

      // 便り（通知一覧）
      match /notifications/{notifId} {
        allow read, update: if request.auth.uid == userId;
      }
    }

    // ===== 歌会 =====
    match /groups/{groupId} {
      allow read: if isAuth();
      // 作成はCloud Function経由のみ
      allow create: if false;
      // オーナーは歌会名を変更可能、メンバーはmemberCountの更新
      // ただし isPublic / purpose / postCount / inviteCode / createdBy / createdAt は変更不可
      allow update: if isAuth()
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['isPublic', 'purpose', 'postCount', 'inviteCode', 'createdBy', 'createdAt']);

      match /members/{memberId} {
        allow read: if isAuth();
        allow create: if isAuth()
                      && request.auth.uid == memberId
                      && !isBanned(groupId)
                      && get(/databases/$(db)/documents/groups/$(groupId)).data.memberCount < 500
                      && request.resource.data.displayName is string
                      && request.resource.data.displayName.size() >= 1
                      && request.resource.data.displayName.size() <= 16;
        allow update: if request.auth.uid == memberId;
        // オーナーは他メンバーを削除可能（追放）、自分自身も削除可能（退会）
        allow delete: if isGroupOwner(groupId) || request.auth.uid == memberId;
      }
    }

    // ===== 投稿 =====
    match /posts/{postId} {
      // 閲覧可の条件（いずれか）:
      //  - 歌会の現メンバー
      //  - 歌会の退会者（pastMembers）※追放者は bannedUsers にのみ載るので除外される
      //  - 公開歌会
      //  - 自分の歌（追放・退会後でも自分の歌にはアクセスできるようにするため）
      //  - 歌会が解散済み（ドキュメント不在）
      // 反故(hogo)投稿は body が空文字化されてサーバー側で退避されるため、
      // ドキュメント自体を読ませても情報漏洩しない。
      allow read: if isAuth() &&
                    (isGroupMember(resource.data.groupId)
                     || wasGroupMember(resource.data.groupId)
                     || isGroupPublic(resource.data.groupId)
                     || isOwnPost(postId)
                     || isGroupDissolved(resource.data.groupId));
      // 作成はCloud Function経由のみ
      allow create: if false;
      // リアクション時に reactionSummary を更新する。
      // 反故投稿へのリアクションもあえて許可している（"いい歌だったのに" 等の反応を残せる
      // ようにするため）。body 等の改ざんは affectedKeys で禁ずる。
      allow update: if isAuth()
                    && isGroupMember(resource.data.groupId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['reactionSummary']);

      // authorId 格納先（Cloud Function経由のみ）
      match /private/{doc} {
        allow read: if false;
        allow write: if false;
      }

      // リアクション
      match /reactions/{reactionId} {
        allow read: if isAuth() && resource.data.userId == request.auth.uid;
        // ブロック関係（双方向）があれば書き込み不可
        allow write: if isAuth()
                     && isGroupMember(
                          get(/databases/$(db)/documents/posts/$(postId)).data.groupId
                        )
                     && !hasBlockRelation(postId);
      }

      // 評
      match /comments/{commentId} {
        // 反故(hogo)評も body はサーバー側で空文字化されているのでメンバー読み取り可。
        // posts の read と同じアクセス条件（現メンバー／退会者／公開歌会／自分の歌／解散済み）。
        allow read: if isAuth() &&
                    (isGroupMember(
                      get(/databases/$(db)/documents/posts/$(postId)).data.groupId
                    )
                    || wasGroupMember(
                      get(/databases/$(db)/documents/posts/$(postId)).data.groupId
                    )
                    || isGroupPublic(
                      get(/databases/$(db)/documents/posts/$(postId)).data.groupId
                    )
                    || isOwnPost(postId)
                    || isGroupDissolved(
                      get(/databases/$(db)/documents/posts/$(postId)).data.groupId
                    ));
        // 作成はCloud Function経由のみ
        allow create: if false;

        // 評のauthorId（Cloud Function経由のみ）
        match /private/{doc} {
          allow read: if false;
          allow write: if false;
        }
      }
    }

    // ===== 通報 =====
    // 作成/更新/削除は Cloud Function 経由のみ。読み取りは本人（通報者）と歌会オーナーのみ。
    match /reports/{reportId} {
      allow read: if isAuth()
                  && (resource.data.reporterId == request.auth.uid
                      || isGroupOwner(resource.data.groupId));
      allow create, update, delete: if false;
    }
  }
}
